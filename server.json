{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.BuyWhere/buywhere-mcp",
  "title": "BuyWhere MCP",
  "description": "Open-source MCP server for AI agent commerce. Search 50M+ products across 6 markets (SG, US, JP, KR, CN, AU).",
  "version": "0.3.7",
  "repository": {
    "url": "https://github.com/BuyWhere/buywhere-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@buywhere/mcp-server",
      "version": "0.3.7",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your BuyWhere API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "BUYWHERE_API_KEY"
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://api.buywhere.ai/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "API key for BuyWhere authentication",
          "isSecret": true
        }
      ]
    }
  ]
}